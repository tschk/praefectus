{
  "id": "praefectus",
  "name": "Praefectus Desktop Actions",
  "description": "Durable, authority-bound desktop action execution through Praefectus",
  "contracts": {
    "tools": [
      "praefectus_capabilities",
      "praefectus_status",
      "praefectus_execute"
    ]
  },
  "activation": { "onStartup": true },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "command": { "type": "string", "minLength": 1 },
      "ledger": { "type": "string", "minLength": 1 },
      "hostExecutorCommand": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "minItems": 1
      }
    }
  }
}
